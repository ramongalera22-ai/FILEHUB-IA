# ============================================
# FILEHUB - Configuración de Servicios IA
# ============================================

# ============================================
# OLLAMA (IA Local)
# ============================================
# URL base de Ollama (por defecto localhost)
VITE_OLLAMA_URL=http://localhost:11434

# Modelo de Ollama a usar (opciones: gemma3:1b, gemma3:4b, llama3, etc.)
VITE_OLLAMA_MODEL=gemma3:4b

# API Key de Ollama (opcional, generalmente no se necesita para local)
VITE_OLLAMA_API_KEY=

# ============================================
# ANYTHINGLLM (Gestión de Documentos IA)
# ============================================
# URL base de AnythingLLM
VITE_ANYTHING_LLM_URL=http://localhost:3001/api/v1

# API Key de AnythingLLM (obtener desde la interfaz de AnythingLLM)
VITE_ANYTHING_LLM_API_KEY=

# Workspace slug de AnythingLLM
VITE_ANYTHING_LLM_WORKSPACE=filehub-ia

# ============================================
# GOOGLE GEMINI (IA Cloud)
# ============================================
# API Key de Google Gemini
VITE_GEMINI_API_KEY=

# ============================================
# SUPABASE (Base de Datos)
# ============================================
# URL de tu proyecto Supabase
VITE_SUPABASE_URL=

# Clave anónima de Supabase
VITE_SUPABASE_ANON_KEY=

# ============================================
# OPEN NOTEBOOK (Opcional)
# ============================================
# URL base de Open Notebook
VITE_OPEN_NOTEBOOK_URL=http://localhost:8000

# API Key de Open Notebook (si aplica)
VITE_OPEN_NOTEBOOK_API_KEY=

# ============================================
# NOTAS DE CONFIGURACIÓN
# ============================================
# 
# 1. OLLAMA:
#    - Asegúrate de que Ollama esté corriendo: ollama serve
#    - Lista modelos disponibles: ollama list
#    - Descarga un modelo: ollama pull gemma3:4b
#
# 2. ANYTHINGLLM:
#    - Instala AnythingLLM desde: https://anythingllm.com/
#    - Obtén tu API key desde Settings > API Keys
#    - Crea un workspace llamado "filehub-ia"
#
# 3. GEMINI:
#    - Obtén tu API key desde: https://makersuite.google.com/app/apikey
#
# 4. SUPABASE:
#    - Crea un proyecto en: https://supabase.com
#    - Copia la URL y la clave anónima desde Project Settings > API
#
# ============================================
